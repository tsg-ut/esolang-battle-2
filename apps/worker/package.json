{
  "name": "@esolang-battle/worker",
  "version": "1.0.0",
  "description": "Esolang Battle 2 Code Evaluation Worker",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx -r dotenv/config src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --alias:@esolang-battle/db=../../packages/db/src/index.ts --alias:@esolang-battle/common=../../packages/common/src/index.ts --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" --outfile=dist/index.js",
    "check:types": "tsc --noEmit",
    "start": "node -r dotenv/config dist/index.js"
  },
  "dependencies": {
    "@esolang-battle/common": "workspace:*",
    "@esolang-battle/db": "workspace:*",
    "bullmq": "^5.74.1",
    "dockerode": "^4.0.10",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "tar-stream": "^3.1.8"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^25.6.0",
    "@types/tar-stream": "^3.1.4",
    "esbuild": "^0.28.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
