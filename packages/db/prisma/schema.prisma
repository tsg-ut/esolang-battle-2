// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../prisma/generated/client"
}

datasource db {
  provider = "postgresql"
}

/// Users that participate in contests and submit solutions
model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  providerImage String?         // Original icon from OAuth provider
  password      String?         // For Credentials provider
  isAdmin       Boolean         @default(false)

  accounts      Account[]
  sessions      Session[]
  Authenticator Authenticator[]
  apiTokens     ApiToken[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  submissions   Submission[]
  testedProblems Problem[]      @relation("ProblemTesters")
  teams         Team[]
}

model ApiToken {
  id        String   @id @default(cuid())
  token     String   @unique
  name      String?  // Description or name for the token
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime?
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

/// Teams that users belong to within a contest
model Team {
  id    Int    @id @default(autoincrement())
  name  String @default("")
  color String

  users   User[]
  contest Contest @relation(fields: [contestId], references: [id])
  contestId Int
}

enum SortOrder {
  ASC
  DESC
}

/// A contest in which users compete by code golf
model Contest {
  id         Int                 @id @default(autoincrement())
  name       String
  startAt    DateTime
  endAt      DateTime
  isPublic   Boolean             @default(true)
  scoreOrder SortOrder           @default(DESC)

  problems Problem[]
  teams    Team[]
  board    Board?
}

/// Scoreboard state for a contest
model Board {
  id                        Int      @id @default(autoincrement())
  contest                   Contest  @relation(fields: [contestId], references: [id])
  contestId                 Int      @unique
  type                      String   // "GRID", "HONEYCOMB", "CROSS_GRID"
  config                    Json     // Static data: e.g. { width, height, cellMapping }
  state                     Json     // Dynamic data: Record<cellId, BoardCell>
  lastProcessedSubmissionId Int?
  lastUpdated               DateTime @default(now())
}

/// Programming language used for submissions
model Language {
  id            Int      @id @default(autoincrement())
  dockerImageId String
  description   String
  name          String

  submissions      Submission[]
  acceptedProblems Problem[]   @relation("ProblemAcceptedLanguages")

  // Judge system relations
  problemCheckers    Problem[]  @relation("ProblemCheckerLanguage")
  problemAggregators Problem[]  @relation("ProblemAggregatorLanguage")
  testCaseCheckers   TestCase[] @relation("TestCaseCheckerLanguage")
}

enum JudgeType {
  BUILTIN
  CUSTOM
}

/// A problem to be solved in the contest
model Problem {
  id               Int        @id @default(autoincrement())
  title            String
  problemStatement String

  contest   Contest @relation(fields: [contestId], references: [id])
  contestId Int

  checkerType       JudgeType @default(BUILTIN)
  checkerName       String    @default("EXACT")
  checkerScript     String?
  checkerConfig     Json      @default("{}")
  checkerLanguage   Language? @relation("ProblemCheckerLanguage", fields: [checkerLanguageId], references: [id])
  checkerLanguageId Int?

  aggregatorType       JudgeType @default(BUILTIN)
  aggregatorName       String    @default("DEFAULT")
  aggregatorScript     String?
  aggregatorConfig     Json      @default("{}")
  aggregatorLanguage   Language? @relation("ProblemAggregatorLanguage", fields: [aggregatorLanguageId], references: [id])
  aggregatorLanguageId Int?

  submissions Submission[]
  testCases  TestCase[]

  /// languages accepted for this problem
  acceptedLanguages Language[] @relation("ProblemAcceptedLanguages")
  /// users that act as testers for this problem
  testers          User[]     @relation("ProblemTesters")
}

/// A test case for a problem
model TestCase {
  id     Int    @id @default(autoincrement())
  input  String
  /// checker script that looks at submission result and assigns score
  checkerScript     String?
  checkerLanguage   Language? @relation("TestCaseCheckerLanguage", fields: [checkerLanguageId], references: [id])
  checkerLanguageId Int?
  output            String
  isSample          Boolean


  problem   Problem   @relation(fields: [problemId], references: [id])
  problemId Int

  executions Execution[]
}

/// Result of running a submission against a single test case
model Execution {
  testcase   TestCase @relation(fields: [testcaseId], references: [id])
  testcaseId Int

  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId Int

  status        ExecutionStatus
  stdout        String?
  stderr        String?
  message       String?   /// Additional info from checker
  executionTime Int       /// e.g. milliseconds
  executedAt    DateTime

  @@id([testcaseId, submissionId])
}

/// A submitted solution to a problem
model Submission {
  id          Int             @id @default(autoincrement())
  code        Bytes
  codeLength  Int
  submittedAt DateTime
  status      ExecutionStatus @default(WJ)
  score       Int?
  message     String?         /// High-level summary from judge

  language   Language @relation(fields: [languageId], references: [id])
  languageId Int

  user   User @relation(fields: [userId], references: [id])
  userId String

  problem   Problem @relation(fields: [problemId], references: [id])
  problemId Int

  executions Execution[]
}

/// Status of execution (e.g. AC/WA/TLE etc.)
enum ExecutionStatus {
  AC
  WA
  TLE
  RE
  WJ
}
